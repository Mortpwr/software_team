page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  background: #f4f6f9;
  --primary: #1a5fb4;
  --primary-muted: #e8f0fc;
  --card: #ffffff;
  --border: #e5e7eb;
  --muted: #6b7280;
  --danger: #b91c1c;
  --success: #047857;
  --warning: #b45309;
}

.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #111827;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: var(--primary-muted);
  color: var(--primary);
}

.tag-muted {
  background: #f3f4f6;
  color: var(--muted);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.btn-ghost {
  background: #fff;
  color: var(--primary);
  border: 1rpx solid var(--primary);
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  color: var(--muted);
  padding: 48rpx 24rpx;
  font-size: 26rpx;
}
