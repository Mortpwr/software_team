.page {
  padding: 24rpx 24rpx 140rpx;
}

.quick {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.q-item {
  font-size: 28rpx;
  color: #1a5fb4;
  font-weight: 600;
  padding: 8rpx 0;
}

.head {
  margin-bottom: 16rpx;
}

.h-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.h-sub {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.timeline {
  margin-bottom: 24rpx;
}

.step {
  display: flex;
  gap: 16rpx;
}

.dot-wrap {
  width: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #d1d5db;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.step-done .dot {
  background: #047857;
}

.step-on .dot {
  background: #1a5fb4;
  box-shadow: 0 0 0 6rpx rgba(26, 95, 180, 0.2);
}

.line {
  width: 4rpx;
  flex: 1;
  background: #e5e7eb;
  margin: 6rpx 0;
  min-height: 40rpx;
}

.step-body {
  flex: 1;
  padding-bottom: 28rpx;
}

.step-name {
  font-size: 28rpx;
  font-weight: 600;
}

.step-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  line-height: 1.45;
}

.step-flag {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #1a5fb4;
  font-weight: 600;
}

.hl {
  font-size: 28rpx;
  font-weight: 600;
}

.hm {
  font-size: 22rpx;
  color: #9ca3af;
  margin: 6rpx 0;
}

.hr {
  font-size: 24rpx;
  color: #4b5563;
}

.task {
  margin-bottom: 16rpx;
}

.t-title {
  font-size: 28rpx;
  font-weight: 600;
}

.t-due {
  font-size: 22rpx;
  color: #b45309;
  margin-top: 8rpx;
}

.tb {
  font-size: 24rpx;
  color: #6b7280;
  margin: 10rpx 0;
  line-height: 1.45;
}

.tdone {
  margin-top: 12rpx;
}
