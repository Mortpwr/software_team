<view class="page">
  <view class="card">
    <view class="label">学生</view>
    <picker mode="selector" range="{{students}}" value="{{studentIndex}}" bindchange="onStu">
      <view class="pv">{{students[studentIndex]}}</view>
    </picker>
    <view class="label mt">调整到阶段</view>
    <picker mode="selector" range="{{stages}}" range-key="name" value="{{stageIndex}}" bindchange="onStage">
      <view class="pv">{{stages[stageIndex].name}}</view>
    </picker>
  </view>
  <button type="primary" bindtap="submit">写入进度并生成提醒任务</button>
</view>
