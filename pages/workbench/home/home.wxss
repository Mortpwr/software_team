.page {
  padding: 24rpx 24rpx 48rpx;
}

.warn {
  background: #fff7ed;
  color: #9a3412;
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.g {
  font-size: 28rpx;
  padding: 10rpx 0;
  color: #1f2937;
}

.menu {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.cell {
  text-align: left;
  font-size: 28rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  color: #111827;
}
