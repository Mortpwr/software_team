<view class="page">
  <view class="card warn" wx:if="{{warn}}">{{warn}}</view>

  <view class="card" wx:if="{{summary}}">
    <view class="g">在册学生 {{summary.students}}</view>
    <view class="g">待审批 {{summary.pendingApps}}</view>
    <view class="g">未命中关键词 {{summary.miss}}</view>
    <view class="g">通知批次 {{summary.batches}} · 短信模拟 {{summary.sms}}</view>
  </view>

  <view class="menu" wx:if="{{role !== 'student'}}">
    <button class="cell" data-path="/pages/workbench/approve/approve" bindtap="go">办事审批</button>
    <button class="cell" data-path="/pages/workbench/publish/publish" bindtap="go">定向通知发布</button>
    <button class="cell" data-path="/pages/workbench/batches/batches" bindtap="go">批次与触达统计</button>
    <button class="cell" data-path="/pages/workbench/misses/misses" bindtap="go">知识库未命中词</button>
    <button class="cell" data-path="/pages/workbench/party-mgmt/party-mgmt" bindtap="go">党团阶段维护</button>
    <button class="cell" data-path="/pages/workbench/logs/logs" bindtap="go">审计日志</button>
  </view>
</view>
