.page {
  padding: 24rpx 24rpx 80rpx;
}

.intro {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.mod-head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 28rpx 0 16rpx;
}

.mid {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a5fb4;
}

.mname {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.mpri {
  font-size: 22rpx;
  color: #9ca3af;
}

.row-item {
  margin-bottom: 20rpx;
}

.fr {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.sc {
  font-size: 22rpx;
  color: #6b7280;
  word-break: break-all;
  margin-bottom: 6rpx;
}

.muted {
  color: #9ca3af;
}

.btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.btn {
  margin: 0;
}

.nfr {
  margin-bottom: 16rpx;
}
