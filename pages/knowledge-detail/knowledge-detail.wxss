.page {
  padding: 24rpx 24rpx 48rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  line-height: 1.35;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.fav-btn {
  margin-top: 20rpx;
}

.meta {
  font-size: 22rpx;
  color: #9ca3af;
}

.block {
  margin-top: 20rpx;
}

.label {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.body {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.65;
  white-space: pre-wrap;
}

.mt {
  margin-top: 24rpx;
}

.link-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}

.link-url {
  display: block;
  font-size: 22rpx;
  color: #1a5fb4;
  margin-top: 6rpx;
  word-break: break-all;
}

.warn {
  background: #fff7ed;
  color: #b45309;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
