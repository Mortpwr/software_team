.wrap {
  padding: 24rpx 24rpx 140rpx;
}

.hero {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #1a5fb4, #3584e4);
  color: #fff;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 24rpx;
  opacity: 0.95;
  line-height: 1.5;
}

.msg-bar {
  margin-bottom: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a5fb4;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.grid-item {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
}

.grid-wide {
  width: 100%;
}

.g-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.g-desc {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.link {
  font-size: 26rpx;
  color: #1a5fb4;
}

.notice {
  margin-bottom: 16rpx;
}

.n-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.n-meta {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.n-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
